{
  "manifest_version": 3,
  "name": "UkrTube",
  "short_name": "UkrTube",
  "version": "1.3.0",
  "description": "Додає на YouTube швидку випадкову стрічку українських відео з фільтрами.",
  "icons": {
    "16": "src/assets/icons/icon16.png",
    "32": "src/assets/icons/icon32.png",
    "48": "src/assets/icons/icon48.png",
    "128": "src/assets/icons/icon128.png"
  },
  "permissions": ["storage", "offscreen"],
  "host_permissions": [
    "https://uatb.bgdn.dev/*",
    "https://www.youtube.com/*",
    "https://i.ytimg.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "action": {
    "default_title": "Налаштування UkrTube",
    "default_icon": {
      "16": "src/assets/icons/icon16.png",
      "32": "src/assets/icons/icon32.png"
    }
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": [
        "src/content/state.js",
        "src/content/platform.js",
        "src/content/filters.js",
        "src/content/view.js",
        "src/content/metadata-enrichment.js",
        "src/content/ai-filter.js",
        "src/content/controller.js"
      ],
      "css": [
        "src/content/chip.css",
        "src/content/layout.css",
        "src/content/filters.css",
        "src/content/cards.css",
        "src/content/date-filter.css",
        "src/content/theme.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
